# ============================================
# 18Studio - Environment Configuration
# ============================================
# Salin file ini menjadi .env dan isi nilainya
# cp .env.example .env

# Server Configuration
PORT=3000

# URL Aplikasi (WAJIB diisi dengan domain Anda saat production!)
# Contoh: https://18studio.id atau https://booking.18studio.id
APP_URL=http://localhost:3000

# DOKU Payment Gateway
# Untuk production, ganti credential ke akun DOKU Production Anda
DOKU_CLIENT_ID=BRN-xxxx-xxxxxxxxxxxx
DOKU_SECRET_KEY=SK-xxxxxxxxxxxxxxxx
DOKU_IS_PRODUCTION=false

# Email (Gmail App Password)
# Buat App Password di: https://myaccount.google.com/apppasswords
EMAIL_USER=yourname@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx
